{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DockStart",
  "version": "0.10.4",
  "identifier": "org.dockstart.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DockStart",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "publisher": "XinXi Xu",
    "icon": [
      "icons/icon.ico"
    ],
    "resources": {}
  }
}
