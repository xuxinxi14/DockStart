{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DockStart",
  "version": "0.8.7",
  "identifier": "org.dockstart.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DockStart",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "resources": {
      "../../../backend/adapters/": "backend/adapters/",
      "../../../backend/dockstart_core/": "backend/dockstart_core/",
      "../../../resources/": "resources/"
    }
  }
}
