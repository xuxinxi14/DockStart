{
  "name": "dockstart-desktop",
  "private": true,
  "version": "0.10.0",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc && vite build",
    "prepare:basic-resources": "python ../../scripts/prepare_basic_release_resources.py --repo-root ../..",
    "prepare:assisted-resources": "python ../../scripts/prepare_assisted_release_resources.py --repo-root ../..",
    "build:desktop": "npm run prepare:basic-resources && tauri build --config src-tauri/tauri.basic.conf.json",
    "build:desktop:assisted": "npm run prepare:assisted-resources && tauri build --config src-tauri/tauri.assisted.conf.json",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "tauri": "tauri"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "3dmol": "^2.5.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.0",
    "vite": "^7.0.0"
  }
}
